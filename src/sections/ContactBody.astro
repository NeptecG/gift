---
import { type Locale, t } from '../i18n/ui';
import { CONTACT } from '../data/contact';
import { HOURS } from '../data/hours';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="container page-head">
  <p class="kicker reveal">{t(locale, 'contact.kicker')}</p>
  <h1 class="page-title reveal" style="--reveal-delay:60ms">{t(locale, 'contact.title')}</h1>
  <p class="page-intro reveal" style="--reveal-delay:120ms">{t(locale, 'contact.intro')}</p>
</section>

<section class="container contact-grid">
  <div class="contact-info reveal">
    <dl class="info-list">
      <div>
        <dt>{t(locale, 'contact.addressLabel')}</dt>
        <dd>{CONTACT.addressL1}<br />{CONTACT.addressL2}</dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.phoneLabel')}</dt>
        <dd><a href={CONTACT.phoneHref}>{CONTACT.phoneLabel}</a></dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.mobileLabel')}</dt>
        <dd><a href={CONTACT.mobileHref}>{CONTACT.mobileLabel}</a> <span class="emergency">({t(locale, 'contact.emergency')})</span></dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.emailLabel')}</dt>
        <dd><a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a></dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.hoursLabel')}</dt>
        <dd>
          {HOURS[locale].map((h, i) => (
            <>{i > 0 && <br />}{h.day}: {h.value}</>
          ))}
        </dd>
      </div>
    </dl>

    <a class="btn btn-primary contact-cta" href={CONTACT.mapDirections} target="_blank" rel="noopener">{t(locale, 'cta.directions')}</a>
  </div>

  <iframe
    class="contact-map reveal"
    style="--reveal-delay:100ms"
    title={locale === 'el' ? 'Χάρτης - Vet & Pet, Ιωαννίνων 34B, Πρέβεζα' : 'Map - Vet & Pet, Ioanninon 34B, Preveza'}
    src={CONTACT.mapEmbed}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen></iframe>
</section>

<style>
  .page-head { padding-top: clamp(2.5rem, 5vw, 4.5rem); padding-bottom: 1.5rem; max-width: 48rem; }
  .page-title { font-size: clamp(2.4rem, 1.4rem + 4vw, 4rem); line-height: 1.04; margin-top: 0.8rem; }
  .page-intro { margin-top: 1.2rem; font-size: 1.2rem; line-height: 1.6; color: var(--color-ink-soft); }

  .contact-grid { display: grid; gap: 2rem; align-items: stretch; padding-bottom: 2rem; }
  @media (min-width: 880px) { .contact-grid { grid-template-columns: 0.85fr 1.15fr; gap: 3rem; } }

  .contact-info { display: flex; flex-direction: column; }
  .info-list { display: grid; gap: 1.4rem; }
  .info-list dt { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-orange); margin-bottom: 0.35rem; }
  .info-list dd { font-size: 1.1rem; line-height: 1.5; }
  .info-list a { color: var(--color-ink); text-decoration: none; border-bottom: 1.5px solid color-mix(in srgb, var(--color-orange) 40%, transparent); }
  .info-list a:hover { border-color: var(--color-orange); }
  .emergency { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; color: var(--color-orange); white-space: nowrap; margin-left: 0.7em; }
  .contact-cta { margin-top: 2rem; align-self: flex-start; }

  .contact-map {
    display: block; width: 100%; height: 100%; min-height: 22rem;
    border: 0; border-radius: 1.2rem;
    box-shadow: 0 1px 0 rgba(26, 22, 14, 0.04), 0 24px 50px -30px rgba(26, 22, 14, 0.4);
  }
  @media (max-width: 879px) { .contact-map { min-height: 18rem; } }
</style>
