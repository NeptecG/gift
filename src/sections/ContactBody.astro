---
import { type Locale, t } from '../i18n/ui';
import SignupForm from '../components/SignupForm.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;

const ADDRESS_L1 = 'Ιωαννίνων 34B';
const ADDRESS_L2 = 'Πρέβεζα, 481 00';
const PHONE = '26820 89457';
const PHONE_HREF = 'tel:+302682089457';
const EMAIL = 'vetandpetpreveza@gmail.com';
const MAP_QUERY = 'Ιωαννίνων 34B, Πρέβεζα 481 00';
const MAP_SRC = `https://maps.google.com/maps?q=${encodeURIComponent(MAP_QUERY)}&z=16&output=embed`;
---

<section class="container page-head">
  <p class="kicker reveal">{t(locale, 'contact.kicker')}</p>
  <h1 class="page-title reveal" style="--reveal-delay:60ms">{t(locale, 'contact.title')}</h1>
  <p class="page-intro reveal" style="--reveal-delay:120ms">{t(locale, 'contact.intro')}</p>
</section>

<section class="container contact-grid">
  <div class="contact-info reveal">
    <dl class="info-list">
      <div>
        <dt>{t(locale, 'contact.addressLabel')}</dt>
        <dd>{ADDRESS_L1}<br />{ADDRESS_L2}</dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.phoneLabel')}</dt>
        <dd><a href={PHONE_HREF}>{PHONE}</a></dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.emailLabel')}</dt>
        <dd><a href={`mailto:${EMAIL}`}>{EMAIL}</a></dd>
      </div>
      <div>
        <dt>{t(locale, 'contact.hoursLabel')}</dt>
        <dd>
          {t(locale, 'hours.weekdays')}: {t(locale, 'hours.weekdaysValue')}<br />
          {t(locale, 'hours.saturday')}: {t(locale, 'hours.saturdayValue')}<br />
          {t(locale, 'hours.sunday')}: {t(locale, 'hours.closed')}
        </dd>
      </div>
    </dl>

    <iframe
      class="contact-map"
      title={locale === 'el' ? 'Χάρτης - Vet & Pet, Ιωαννίνων 34B, Πρέβεζα' : 'Map - Vet & Pet, Ioanninon 34B, Preveza'}
      src={MAP_SRC}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen></iframe>
  </div>

  <div class="contact-form-wrap reveal" style="--reveal-delay:100ms">
    <h2 class="form-title">{t(locale, 'contact.formTitle')}</h2>
    <SignupForm locale={locale} variant="contact" />
  </div>
</section>

<style>
  .page-head { padding-top: clamp(2.5rem, 5vw, 4.5rem); padding-bottom: 1.5rem; max-width: 48rem; }
  .page-title { font-size: clamp(2.4rem, 1.4rem + 4vw, 4rem); line-height: 1.04; margin-top: 0.8rem; }
  .page-intro { margin-top: 1.2rem; font-size: 1.2rem; line-height: 1.6; color: var(--color-ink-soft); }

  .contact-grid { display: grid; gap: 2rem; align-items: start; padding-bottom: 2rem; }
  @media (min-width: 880px) { .contact-grid { grid-template-columns: 0.9fr 1.1fr; gap: 3rem; } }

  .info-list { display: grid; gap: 1.4rem; }
  .info-list dt { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-orange); margin-bottom: 0.35rem; }
  .info-list dd { font-size: 1.1rem; line-height: 1.5; }
  .info-list a { color: var(--color-ink); text-decoration: none; border-bottom: 1.5px solid color-mix(in srgb, var(--color-orange) 40%, transparent); }
  .info-list a:hover { border-color: var(--color-orange); }

  .contact-map {
    display: block; width: 100%; height: 17rem;
    margin-top: 1.8rem; border: 0; border-radius: 1rem;
    box-shadow: 0 1px 0 rgba(26, 22, 14, 0.04);
  }

  .contact-form-wrap {
    background: var(--color-paper-raised);
    border: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
    border-radius: 1.3rem; padding: clamp(1.5rem, 3vw, 2.2rem);
  }
  .form-title { font-size: 1.7rem; margin-bottom: 1.3rem; }
</style>
