---
import { type Locale, t, localizedPath } from '../i18n/ui';
import { Image } from 'astro:assets';
import katerina from '../assets/about-katerina.jpg';

interface Props { locale: Locale }
const { locale } = Astro.props;

// img: optional icon image for the #F0D9CC box (path under /public). Empty box until set.
const values: { t: string; d: string; img?: string }[] = [
  { t: t(locale, 'about.value1.title'), d: t(locale, 'about.value1.body'), img: '/images/about/values/love.png' },
  { t: t(locale, 'about.value2.title'), d: t(locale, 'about.value2.body'), img: '/images/about/values/respect.png' },
  { t: t(locale, 'about.value3.title'), d: t(locale, 'about.value3.body'), img: '/images/about/values/science.png' },
];
---

<section class="container page-head">
  <p class="kicker reveal">{t(locale, 'about.kicker')}</p>
  <h1 class="page-title reveal" style="--reveal-delay:60ms">{t(locale, 'about.title')}</h1>
  <p class="about-lead reveal" style="--reveal-delay:120ms">{t(locale, 'about.lead')}</p>
</section>

<!-- Team: alternating left / right -->
<section class="container team">
  <article class="person reveal">
    <div class="person-photo">
      <Image src={katerina} alt={locale === 'el' ? 'Η Κατερίνα στο Vet & Pet' : 'Katerina at Vet & Pet'} widths={[400, 640, 900]} sizes="(max-width: 820px) 92vw, 32rem" />
    </div>
    <div class="person-text">
      <p class="person-role">{t(locale, 'about.p1.role')}</p>
      <h2 class="person-name">{t(locale, 'about.p1.name')}</h2>
      <p class="person-body">{t(locale, 'about.p1.body')}</p>
    </div>
  </article>

  <article class="person person--reverse reveal">
    <div class="person-photo">
      <img src="/images/about/mama.svg" alt={locale === 'el' ? 'Η μαμά της Κατερίνας, βοηθός στο Vet & Pet' : "Katerina's mom, helper at Vet & Pet"} width="900" height="1200" loading="lazy" />
    </div>
    <div class="person-text">
      <p class="person-role">{t(locale, 'about.p2.role')}</p>
      <h2 class="person-name">{t(locale, 'about.p2.name')}</h2>
      <p class="person-body">{t(locale, 'about.p2.body')}</p>
    </div>
  </article>
</section>

<!-- Values -->
<section class="container values">
  <h2 class="values-title reveal">{t(locale, 'about.values.title')}</h2>
  <div class="values-grid">
    {values.map((v, i) => (
      <article class="value-card reveal" style={`--reveal-delay:${i * 90}ms`}>
        <span class="value-paw" data-val={v.img?.split('/').pop()?.replace('.png', '')}>{v.img && <img src={v.img} alt="" class="value-paw-img" width="40" height="40" loading="lazy" decoding="async" />}</span>
        <h3 class="value-name">{v.t}</h3>
        <p class="value-body">{v.d}</p>
      </article>
    ))}
  </div>
  <div class="values-cta reveal">
    <a href={localizedPath(locale, '/contact')} class="btn btn-primary">{t(locale, 'cta.contactUs')}</a>
  </div>
</section>

<style>
  .page-head { padding-top: clamp(2.5rem, 5vw, 4.5rem); padding-bottom: 1rem; max-width: 50rem; }
  .page-title { font-size: clamp(2.4rem, 1.4rem + 4vw, 4.2rem); line-height: 1.04; margin-top: 0.8rem; }
  .about-lead { margin-top: 1.2rem; font-size: 1.35rem; line-height: 1.55; color: var(--color-ink); font-family: var(--font-serif); font-style: italic; max-width: 40rem; }

  .team { display: grid; gap: clamp(2.5rem, 6vw, 5rem); padding-top: clamp(1.5rem, 4vw, 3rem); }
  .person { display: grid; gap: 1.8rem; align-items: center; }
  @media (min-width: 820px) {
    .person { grid-template-columns: 0.9fr 1.1fr; gap: 3.5rem; }
    .person--reverse .person-photo { order: 2; }
  }
  .person-photo {
    border-radius: 1.4rem; overflow: hidden;
    aspect-ratio: 4 / 5; background: var(--color-sand);
    border: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
    box-shadow: 0 24px 50px -30px rgba(26, 22, 14, 0.45);
  }
  .person-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .person-role {
    font-family: var(--font-sans); font-weight: 700; font-size: 0.8rem;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--color-orange);
  }
  .person-name { font-size: clamp(2rem, 1.2rem + 2.6vw, 3rem); line-height: 1.05; margin-top: 0.5rem; }
  .person-body { margin-top: 1rem; font-size: 1.18rem; line-height: 1.7; color: var(--color-ink-soft); max-width: 36rem; }

  .values { padding-top: clamp(3rem, 6vw, 5rem); }
  .values-title { font-size: clamp(1.8rem, 1.2rem + 2vw, 2.6rem); margin-bottom: 2rem; }
  .values-grid { display: grid; gap: 1.4rem; grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }
  .value-card {
    background: var(--color-paper-raised);
    border: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
    border-radius: var(--radius-card); padding: 1.8rem 1.6rem;
  }
  .value-paw { display: inline-grid; place-items: center; width: 3rem; height: 3rem; border-radius: 0.8rem; background: var(--color-orange-soft); overflow: hidden; }
  .value-paw-img { width: 2.28rem; height: 2.28rem; object-fit: contain; display: block; }
  /* science is tall + thin, reads small — bump it 30% like the stethoscope */
  .value-paw[data-val="science"] .value-paw-img { width: 2.59rem; height: 2.59rem; }
  .value-name { font-size: 1.5rem; margin-top: 1rem; }
  .value-body { margin-top: 0.5rem; color: var(--color-ink-soft); line-height: 1.55; }
  .values-cta { margin-top: 2.5rem; display: flex; justify-content: center; }
</style>
