---

import '../styles/fonts.ts';
import '../styles/global.css';
import { type Locale, t, type UIKey } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  locale: Locale;
  /** route key, e.g. "/", "/shop" - used for hreflang + language switch */
  path: string;
  titleKey: UIKey;
  descKey: UIKey;
}
const { locale, path, titleKey, descKey } = Astro.props;

const title = t(locale, titleKey);
const description = t(locale, descKey);
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const elPath = path === '/' ? '/' : path;
const enPath = path === '/' ? '/en/' : '/en' + path;
const canonicalUrl = site + (locale === 'el' ? elPath : enPath);
const ogImage = site + '/og-image.png';
const isHome = path === '/';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#D9531E" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="el" href={site + elPath} />
    <link rel="alternate" hreflang="en" href={site + enPath} />
    <link rel="alternate" hreflang="x-default" href={site + elPath} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vet & Pet" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={locale === 'el' ? 'el_GR' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'el' ? 'en_US' : 'el_GR'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    {isHome && <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VeterinaryCare",
      "name": "Vet & Pet",
      "description": "Κτηνιατρείο και pet shop στην Πρέβεζα. Φροντίδα με αγάπη για κάθε ζώο.",
      "url": site + "/",
      "telephone": "+302682089457",
      "email": "vetandpetpreveza@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Ιωαννίνων 34B",
        "addressLocality": "Πρέβεζα",
        "postalCode": "48100",
        "addressCountry": "GR"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "15:00"
        }
      ],
      "sameAs": [
        "https://www.facebook.com/vet.and.pet.katerina.giaprou",
        "https://instagram.com/vet_and_pet_preveza"
      ]
    })} />}
  </head>
  <body>
    <a href="#main" class="skip-link">{locale === 'el' ? 'Μετάβαση στο περιεχόμενο' : 'Skip to content'}</a>
    <Header locale={locale} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <script>
      const els = document.querySelectorAll('.reveal');
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0.5rem;
        z-index: 100;
        background: var(--color-ink);
        color: var(--color-paper-raised);
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
      }
      .skip-link:focus { left: 0.5rem; }
    </style>
  </body>
</html>
