---

import '../styles/fonts.ts';
import '../styles/global.css';
import { type Locale, t, type UIKey } from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  locale: Locale;
  /** route key, e.g. "/", "/shop" — used for hreflang + language switch */
  path: string;
  titleKey: UIKey;
  descKey: UIKey;
}
const { locale, path, titleKey, descKey } = Astro.props;

const title = t(locale, titleKey);
const description = t(locale, descKey);
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const elPath = path === '/' ? '/' : path;
const enPath = path === '/' ? '/en/' : '/en' + path;
const ogImage = site + '/logo.png';
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="alternate" hreflang="el" href={site + elPath} />
    <link rel="alternate" hreflang="en" href={site + enPath} />
    <link rel="alternate" hreflang="x-default" href={site + elPath} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={locale === 'el' ? 'el_GR' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a href="#main" class="skip-link">{locale === 'el' ? 'Μετάβαση στο περιεχόμενο' : 'Skip to content'}</a>
    <Header locale={locale} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <script>
      const els = document.querySelectorAll('.reveal');
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0.5rem;
        z-index: 100;
        background: var(--color-ink);
        color: var(--color-paper-raised);
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
      }
      .skip-link:focus { left: 0.5rem; }
    </style>
  </body>
</html>
