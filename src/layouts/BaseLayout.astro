---

import '../styles/fonts.ts';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { type Locale, t, type UIKey, localizedPath, faq } from '../i18n/ui';
import { CONTACT } from '../data/contact';
import { OPENING_HOURS_SCHEMA } from '../data/hours';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';

const GA_ID = 'G-2KGC12RDD2';

interface Props {
  locale: Locale;
  /** route key, e.g. "/", "/shop" - used for hreflang + language switch */
  path: string;
  titleKey: UIKey;
  descKey: UIKey;
}
const { locale, path, titleKey, descKey } = Astro.props;

const title = t(locale, titleKey);
const description = t(locale, descKey);
const site = Astro.site?.toString().replace(/\/$/, '') ?? '';
const elPath = localizedPath('el', path);
const enPath = localizedPath('en', path);
const canonicalUrl = site + (locale === 'el' ? elPath : enPath);
const ogImage = site + '/og-image.jpg';
const isHome = path === '/';
const isFaq = path === '/faq';

// LocalBusiness schema (home only) - services pulled from the content collection so it stays in sync.
const serviceList = isHome
  ? (await getCollection('services'))
      .sort((a, b) => a.data.order - b.data.order)
      .map((s) => ({
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: locale === 'el' ? s.data.title_el : s.data.title_en },
      }))
  : [];

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'VeterinaryCare',
  name: 'Vet & Pet',
  description:
    locale === 'el'
      ? 'Κτηνιατρείο και pet shop στην Πρέβεζα. Φροντίδα με αγάπη για κάθε ζώο.'
      : 'Veterinary clinic and pet shop in Preveza. Caring for every animal with love.',
  url: site + '/',
  image: ogImage,
  logo: site + '/favicon.png',
  telephone: CONTACT.phoneHref.replace('tel:', ''),
  email: CONTACT.email,
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Ιωαννίνων 34B',
    addressLocality: 'Πρέβεζα',
    postalCode: '48100',
    addressCountry: 'GR',
  },
  areaServed: { '@type': 'City', name: 'Πρέβεζα' },
  geo: { '@type': 'GeoCoordinates', latitude: 38.96507457378602, longitude: 20.74910738429623 },
  hasMap: CONTACT.mapDirections,
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: locale === 'el' ? 'Υπηρεσίες' : 'Services',
    itemListElement: serviceList,
  },
  sameAs: [CONTACT.facebookHref, CONTACT.instagramHref],
};

const faqSchema = isFaq
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq[locale].map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="256x256" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#D9531E" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="alternate" hreflang="el" href={site + elPath} />
    <link rel="alternate" hreflang="en" href={site + enPath} />
    <link rel="alternate" hreflang="x-default" href={site + elPath} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Vet & Pet" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Vet & Pet - Κτηνιατρείο & Pet Shop, Πρέβεζα" />
    <meta property="og:locale" content={locale === 'el' ? 'el_GR' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'el' ? 'en_US' : 'el_GR'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="Vet & Pet - Κτηνιατρείο & Pet Shop, Πρέβεζα" />

    {isHome && <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />}
    {isFaq && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </head>
  <body>
    <a href="#main" class="skip-link">{locale === 'el' ? 'Μετάβαση στο περιεχόμενο' : 'Skip to content'}</a>
    <Header locale={locale} path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <CookieConsent locale={locale} gaId={GA_ID} />
    <script>
      const els = document.querySelectorAll('.reveal');
      if (els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0.5rem;
        z-index: 100;
        background: var(--color-ink);
        color: var(--color-paper-raised);
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
      }
      .skip-link:focus { left: 0.5rem; }
    </style>
  </body>
</html>
