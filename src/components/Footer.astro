---
import { type Locale, t, localizedPath } from '../i18n/ui';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const year = new Date().getFullYear();

// Contact lives in the "Visit us" column, so it's dropped from the footer nav list.
const nav = [
  { key: 'nav.home', route: '/' },
  { key: 'nav.services', route: '/services' },
  { key: 'nav.shop', route: '/shop' },
  { key: 'nav.gallery', route: '/gallery' },
  { key: 'nav.about', route: '/about' },
] as const;

const ADDRESS_L1 = 'Ιωαννίνων 34B';
const ADDRESS_L2 = 'Πρέβεζα, 481 00';
const PHONE_LABEL = '26820 89457';
const PHONE_HREF = 'tel:+302682089457';
const EMAIL = 'vetandpetpreveza@gmail.com';
const INSTAGRAM = 'vet_and_pet_preveza';
const VIBER_LABEL = '+30 694 865 9158';
const MESSENGER_LABEL = 'Vet & Pet - Katerina Giaprou';
// [PLACEHOLDER] exact m.me handle unknown - links to the Facebook page search for now.
const MESSENGER_HREF = 'https://www.facebook.com/search/top?q=' + encodeURIComponent(MESSENGER_LABEL);
---

<footer class="site-footer">
  <div class="foot-main container grid gap-10 py-14 sm:grid-cols-2 md:grid-cols-[1.6fr_0.9fr_1.1fr_1fr]">
    <div class="foot-brand">
      <img src="/logo.png" class="foot-logo" alt="Vet & Pet" width="120" height="120" />
      <p class="foot-tagline">{t(locale, 'footer.tagline')}<br />{t(locale, 'footer.tagline2')}</p>

      <div class="foot-socials">
        <a class="foot-chip" href={`https://instagram.com/${INSTAGRAM}`} target="_blank" rel="noopener" aria-label={`Instagram: ${INSTAGRAM}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/></svg>
        </a>

        <a class="foot-chip" href={`viber://chat?number=%2B306948659158`} aria-label={`Viber: ${VIBER_LABEL}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.5c4.4 0 7.5 2.8 7.5 6.8 0 4-3.1 6.8-7.5 6.8-.8 0-1.5-.08-2.2-.24L6 20l.5-3.1A6.6 6.6 0 0 1 4.5 10.3C4.5 6.3 7.6 3.5 12 3.5z"/><path d="M9.2 8.2c1.2-.2 2.4.3 3.2 1.1.8.8 1.3 2 1.1 3.2" stroke-width="1.5"/></svg>
        </a>

        <a class="foot-chip" href={MESSENGER_HREF} target="_blank" rel="noopener" aria-label={`Messenger: ${MESSENGER_LABEL}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3.2c5 0 8.8 3.6 8.8 8.2S17 19.6 12 19.6c-1 0-1.9-.12-2.8-.35L5 21l.4-3.4A8 8 0 0 1 3.2 11.4C3.2 6.8 7 3.2 12 3.2z"/><path d="M7.5 13.3l2.8-3 2 1.6 2.3-2.2" stroke-width="1.5"/></svg>
        </a>
      </div>
    </div>

    <nav class="foot-col" aria-label={t(locale, 'footer.explore')}>
      <h2 class="foot-h">{t(locale, 'footer.explore')}</h2>
      <ul>
        {nav.map((item) => (
          <li><a href={localizedPath(locale, item.route)}>{t(locale, item.key)}</a></li>
        ))}
      </ul>
    </nav>

    <div class="foot-col">
      <h2 class="foot-h">{t(locale, 'footer.visit')}</h2>
      <ul class="foot-contact">
        <li>{ADDRESS_L1}<br />{ADDRESS_L2}</li>
        <li><a href={PHONE_HREF}>{PHONE_LABEL}</a></li>
        <li><a href={`mailto:${EMAIL}`}>{EMAIL}</a></li>
      </ul>
    </div>

    <div class="foot-col">
      <h2 class="foot-h">{t(locale, 'contact.hoursLabel')}</h2>
      <dl class="foot-hours">
        <div><dt>{t(locale, 'hours.weekdays')}</dt><dd>{t(locale, 'hours.weekdaysValue')}</dd></div>
        <div><dt>{t(locale, 'hours.saturday')}</dt><dd>{t(locale, 'hours.saturdayValue')}</dd></div>
        <div><dt>{t(locale, 'hours.sunday')}</dt><dd>{t(locale, 'hours.closed')}</dd></div>
      </dl>
    </div>
  </div>

  <div class="foot-bar">
    <div class="container flex flex-col items-center justify-between gap-2 py-5 text-sm sm:flex-row">
      <p>© {year} Vet &amp; Pet. {t(locale, 'footer.rights')}</p>
      <p class="foot-made">{locale === 'el' ? 'Φτιαγμένο με αγάπη για τα ζώα' : 'Made with love for animals'} <span aria-hidden="true">🐾</span></p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 6rem;
    background: var(--color-ink);
    color: color-mix(in srgb, var(--color-paper) 85%, transparent);
  }
  .foot-logo {
    display: block;
    width: 6.5rem;
    height: auto;
    border-radius: 1rem;
    margin-bottom: 1.1rem;
    margin-left: 0;
    background: var(--color-paper);
  }
  .foot-tagline { max-width: 24rem; line-height: 1.55; }

  .foot-socials { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.4rem; }
  .foot-chip {
    display: grid; place-items: center;
    width: 2.8rem; height: 2.8rem; border-radius: 0.7rem;
    background: color-mix(in srgb, var(--color-paper) 7%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-paper) 13%, transparent);
    color: var(--color-paper); text-decoration: none;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.15s ease, color 0.2s ease;
  }
  .foot-chip svg { width: 1.3rem; height: 1.3rem; color: var(--color-orange); transition: color 0.2s ease; }
  .foot-chip:hover {
    background: var(--color-orange); border-color: var(--color-orange);
    transform: translateY(-2px);
  }
  .foot-chip:hover svg { color: var(--color-paper-raised); }

  .foot-h {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 1rem;
  }
  .foot-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .foot-col a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  .foot-col a:hover { color: var(--color-orange); }
  .foot-contact { line-height: 1.5; }
  .foot-contact li { color: color-mix(in srgb, var(--color-paper) 80%, transparent); }

  .foot-hours { display: flex; flex-direction: column; gap: 0.55rem; }
  .foot-hours > div { display: flex; justify-content: space-between; gap: 1.5rem; white-space: nowrap; }
  .foot-hours dt { color: color-mix(in srgb, var(--color-paper) 65%, transparent); }
  .foot-hours dd { color: var(--color-paper-raised); font-variant-numeric: tabular-nums; }

  .foot-bar {
    border-top: 1px solid color-mix(in srgb, var(--color-paper) 12%, transparent);
    color: color-mix(in srgb, var(--color-paper) 60%, transparent);
  }
  .foot-made { display: inline-flex; align-items: center; gap: 0.4rem; }
</style>
