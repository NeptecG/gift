---
/** Line icons for services. Stroke = currentColor. */
interface Props { name: string; class?: string; }
const { name, class: cls = '' } = Astro.props;
const common = {
  class: cls,
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '1.6',
  'stroke-linecap': 'round' as const,
  'stroke-linejoin': 'round' as const,
  'aria-hidden': 'true',
};
---

{name === 'stethoscope' && (
  <svg {...common}><path d="M5 3v5a4 4 0 0 0 8 0V3" /><path d="M5 3H3.5M13 3h1.5" /><path d="M9 16v1a4 4 0 0 0 8 0v-2" /><circle cx="19" cy="13" r="2" /></svg>
)}
{name === 'syringe' && (
  <svg {...common}><path d="M14 4l6 6" /><path d="M16.5 6.5l-9 9-3.5 1 1-3.5 9-9z" /><path d="M9 11l2 2M12 8l2 2" /><path d="M4 20l2-2" /></svg>
)}
{name === 'chip' && (
  <svg {...common}><rect x="6" y="6" width="12" height="12" rx="2" /><path d="M9 9h6v6H9z" /><path d="M9 3v2M15 3v2M9 19v2M15 19v2M3 9h2M3 15h2M19 9h2M19 15h2" /></svg>
)}
{name === 'scalpel' && (
  <svg {...common}><path d="M4 20l8-8" /><path d="M13 11l7-7-1 6-6 1z" /><path d="M4 20l2-1" /></svg>
)}
{name === 'tooth' && (
  <svg {...common}><path d="M12 4c-2.5-1.5-6-1-7 1.5C4 9 5.5 11 6 14c.4 2.4.6 6 2 6s1.3-4 2-4 .6 4 2 4 1.6-3.6 2-6c.5-3 2-5 1-8.5C16 3 14.5 2.5 12 4z" /></svg>
)}
{name === 'shield' && (
  <svg {...common}><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6z" /><path d="M9 12l2 2 4-4" /></svg>
)}
{name === 'bowl' && (
  <svg {...common}><path d="M3 11h18a9 9 0 0 1-18 0z" /><path d="M5.5 11a6.5 6.5 0 0 1 13 0" /></svg>
)}
{name === 'heart' && (
  <svg {...common}><path d="M12 20s-7-4.2-7-9a4 4 0 0 1 7-2.5A4 4 0 0 1 19 11c0 4.8-7 9-7 9z" /></svg>
)}
