---
/**
 * Framed image used for the hero art and the About centerpiece.
 * Served through Astro's image pipeline (resized + webp).
 *
 * Props:
 *   image   imported ImageMetadata
 *   alt     alt text
 *   caption optional caption under the frame
 *   eager   LCP hint
 *   blend   multiply-blend the image into the paper (for cream-bg line art)
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
  class?: string;
  caption?: string;
  eager?: boolean;
  blend?: boolean;
}
const { image, alt, class: cls = '', caption, eager = false, blend = false } = Astro.props;
---

<figure class={`hp-figure ${cls}`}>
  <div class="hp-frame">
    <Image
      src={image}
      alt={alt}
      widths={[480, 768, 1100]}
      sizes="(max-width: 768px) 92vw, 560px"
      loading={eager ? 'eager' : 'lazy'}
      class:list={['hp-img', { blend }]}
    />
  </div>
  {caption && <figcaption class="hp-caption">{caption}</figcaption>}
</figure>

<style>
  .hp-figure { margin: 0; }
  .hp-frame {
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--color-paper-raised);
    box-shadow:
      0 1px 0 rgba(26, 22, 14, 0.04),
      0 24px 50px -28px rgba(26, 22, 14, 0.4);
    border: 1px solid rgba(26, 22, 14, 0.08);
  }
  .hp-img {
    display: block;
    width: 100%;
    height: auto;
  }
  .hp-img.blend { mix-blend-mode: multiply; } /* cream-bg line art melts into paper */
  .hp-caption {
    margin-top: 0.9rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.4;
    color: var(--color-ink-soft);
    text-align: center;
    max-width: 30rem;
    margin-inline: auto;
  }
</style>
