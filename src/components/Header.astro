---
import { type Locale, t, localizedPath, altLocalePath } from '../i18n/ui';
import CatAccent from './art/CatAccent.astro';
import { Image } from 'astro:assets';
import logoBeige from '../assets/logo-beige.png';

interface Props {
  locale: Locale;
  path: string; // current route key, e.g. "/shop"
}
const { locale, path } = Astro.props;

const nav = [
  { key: 'nav.home', route: '/' },
  { key: 'nav.services', route: '/services' },
  { key: 'nav.shop', route: '/shop' },
  { key: 'nav.gallery', route: '/gallery' },
  { key: 'nav.about', route: '/about' },
  { key: 'nav.contact', route: '/contact' },
] as const;

const homeHref = localizedPath(locale, '/');
const altHref = altLocalePath(locale, path);
---

<header class="site-header">
  <div class="container flex items-center justify-between gap-4 py-1">
    <a href={homeHref} class="brand" aria-label="Vet & Pet - home">
      <Image src={logoBeige} class="brand-logo" alt="" format="webp" widths={[120, 240]} sizes="120px" fetchpriority="high" />
      <span class="brand-word">Vet <span class="amp">&amp;</span> Pet</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      {nav.map((item) => {
        const href = localizedPath(locale, item.route);
        const active = path === item.route;
        return (
          <a href={href} class:list={['nav-link', { active }]} aria-current={active ? 'page' : undefined}>
            {t(locale, item.key)}
          </a>
        );
      })}
    </nav>

    <div class="header-actions">
      <a href={altHref} class="lang-switch" hreflang={locale === 'en' ? 'el' : 'en'} aria-label={locale === 'en' ? 'Ελληνικά' : 'English'}>
        {t(locale, 'lang.switch')}
      </a>
      <button type="button" class="menu-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label={t(locale, 'nav.menu')}>
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Primary mobile" hidden>
    {nav.map((item) => {
      const href = localizedPath(locale, item.route);
      const active = path === item.route;
      return (
        <a href={href} class:list={['mobile-link', { active }]} aria-current={active ? 'page' : undefined}>
          <CatAccent variant="paw" class="mobile-paw" />
          {t(locale, item.key)}
        </a>
      );
    })}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--color-paper) 92%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 9%, transparent);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--color-ink);
  }
  .brand-logo {
    height: 4.2rem;
    width: auto;
    object-fit: contain;
    flex: none;
  }
  .brand-word {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: 0.01em;
    line-height: 1;
    white-space: nowrap;
  }
  .brand-word .amp { color: var(--color-orange); font-style: italic; }

  .primary-nav { display: none; }
  @media (min-width: 1024px) {
    .primary-nav { display: flex; align-items: center; gap: 0.4rem; }
  }
  .nav-link {
    position: relative;
    padding: 0.4rem 0.7rem;
    font-size: 1.02rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    text-decoration: none;
    border-radius: 0.5rem;
    transition: color 0.2s ease, background-color 0.2s ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0.7rem; right: 0.7rem; bottom: 0.18rem;
    height: 2px;
    background: var(--color-orange);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-link:hover { color: var(--color-orange); }
  .nav-link.active { color: var(--color-orange); }
  .nav-link.active::after { transform: scaleX(1); } /* underline marks the current page only */

  .header-actions { display: flex; align-items: center; gap: 0.6rem; margin-right: -0.25rem; }
  .lang-switch {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    color: var(--color-ink);
    text-decoration: none;
    padding: 0.35rem 0.62rem;
    border: 1px solid color-mix(in srgb, var(--color-ink) 22%, transparent);
    border-radius: 999px;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .lang-switch:hover {
    background: var(--color-ink);
    color: var(--color-paper-raised);
    border-color: var(--color-ink);
  }

  .menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.4rem; height: 2.4rem;
    padding: 0.5rem;
    background: none;
    border: 1px solid color-mix(in srgb, var(--color-ink) 18%, transparent);
    border-radius: 0.6rem;
    cursor: pointer;
  }
  .menu-toggle span {
    display: block; height: 2px; width: 100%;
    background: var(--color-ink);
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .menu-toggle[aria-expanded='true'] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .menu-toggle[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded='true'] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  @media (min-width: 1024px) { .menu-toggle { display: none; } }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 0.5rem 1rem 1rem;
    border-top: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
    background: var(--color-paper);
  }
  .mobile-nav[hidden] { display: none; }
  .mobile-link {
    display: flex; align-items: center; gap: 0.7rem;
    padding: 0.85rem 0.5rem;
    font-family: var(--font-serif);
    font-size: 1.4rem;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 7%, transparent);
  }
  :global(.mobile-paw) { width: 1.1rem; height: 1.1rem; color: var(--color-orange); flex: none; opacity: 0.55; }
  .mobile-link.active { color: var(--color-orange); }
  @media (min-width: 1024px) { .mobile-nav { display: none !important; } }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
</script>
